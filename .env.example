# Database
DATABASE_URL="postgresql://user:password@host:5432/locos?pgbouncer=true&connection_limit=10"
DATABASE_URL_DIRECT="postgresql://user:password@host:5432/locos"

# Redis (Upstash)
REDIS_URL="https://your-redis.upstash.io"
REDIS_TOKEN="your-redis-token"

# Typesense
TYPESENSE_HOST="your-cluster.typesense.net"
TYPESENSE_PORT="443"
TYPESENSE_PROTOCOL="https"
TYPESENSE_API_KEY="your-api-key"

# Qdrant
QDRANT_URL="https://your-cluster.qdrant.io"
QDRANT_API_KEY="your-api-key"

# OpenAI
OPENAI_API_KEY="sk-..."

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN="pk.eyJ1..."

# Cloudflare R2
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key"
R2_SECRET_ACCESS_KEY="your-secret"
R2_BUCKET_NAME="locos-media"
R2_PUBLIC_URL="https://media.locos.app"

# Stripe
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# Auth
NEXTAUTH_SECRET="your-32-char-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# App
NEXT_PUBLIC_APP_URL="https://locos.app"
SENTRY_DSN="https://your-dsn.ingest.sentry.io"
