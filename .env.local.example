# ─────────────────────────────────────────────────────────────────────────────
# LOCOS — Local Development Environment
# Copy this file to .env.local and fill in your values.
# Lines marked [REQUIRED] must be set before `npm run dev` will start.
# Lines marked [OPTIONAL-DEV] can be left as dummy values for local testing.
# ─────────────────────────────────────────────────────────────────────────────

# ─── DATABASE [REQUIRED] ──────────────────────────────────────────────────────
# Pooled URL (used by the app at runtime via PgBouncer / Neon pooler)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/locos_dev"

# Direct URL (used only by Prisma CLI for migrations — bypasses PgBouncer)
DATABASE_URL_DIRECT="postgresql://postgres:postgres@localhost:5432/locos_dev"

# ─── REDIS [REQUIRED] ─────────────────────────────────────────────────────────
# Upstash Redis REST endpoint — free tier works for dev
# Create at: https://console.upstash.com
REDIS_URL="https://YOUR-REDIS-ID.upstash.io"
REDIS_TOKEN="YOUR_UPSTASH_REDIS_TOKEN"

# ─── AUTH [REQUIRED] ──────────────────────────────────────────────────────────
# Must be at least 32 characters — use: openssl rand -hex 32
NEXTAUTH_SECRET="change-me-to-a-random-32-char-string-minimum"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── OPENAI [REQUIRED for AI features] ────────────────────────────────────────
# Create at: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-your-openai-key-here"

# ─── TYPESENSE [REQUIRED for search] ──────────────────────────────────────────
# Free hosted cluster at: https://cloud.typesense.org (or run locally — see README)
TYPESENSE_HOST="your-cluster.typesense.net"
TYPESENSE_PORT="443"
TYPESENSE_PROTOCOL="https"
TYPESENSE_API_KEY="your-typesense-admin-api-key"

# ─── QDRANT [REQUIRED for semantic search] ────────────────────────────────────
# Free tier at: https://cloud.qdrant.io
QDRANT_URL="https://YOUR-CLUSTER-ID.us-east-1-0.aws.cloud.qdrant.io"
QDRANT_API_KEY="your-qdrant-api-key"

# ─── MAPBOX [REQUIRED for map view] ───────────────────────────────────────────
# Free tier at: https://account.mapbox.com/access-tokens
NEXT_PUBLIC_MAPBOX_TOKEN="pk.eyJ1IjoieW91ci11c2VybmFtZSIsImEiOiJja..."

# ─── CLOUDFLARE R2 [OPTIONAL-DEV — only needed for image upload] ──────────────
# Create bucket at: https://dash.cloudflare.com → R2
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="locos-media-dev"
R2_PUBLIC_URL="https://your-custom-domain-or-r2.dev-url"

# ─── STRIPE [OPTIONAL-DEV — only needed for payment flow] ────────────────────
# Test keys at: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_your-stripe-test-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-pub-key"

# ─── APP [REQUIRED] ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── SENTRY [OPTIONAL-DEV] ───────────────────────────────────────────────────
# Leave blank locally — Sentry is disabled when SENTRY_DSN is not set
SENTRY_DSN=""

# ─── CRON SECURITY [OPTIONAL-DEV] ────────────────────────────────────────────
# Used to authenticate /api/cron/* endpoints — any string works locally
CRON_SECRET="local-dev-cron-secret"
